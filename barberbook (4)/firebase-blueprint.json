{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A service offered by the barber",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["corte", "barba", "finalização", "combo"] },
        "imageUrl": { "type": "string" },
        "duration": { "type": "number", "description": "Duration in minutes" }
      },
      "required": ["name", "price", "category"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A booking made by a customer",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "notes": { "type": "string", "description": "Barber notes for the service" },
        "price": { "type": "number" }
      },
      "required": ["customerId", "serviceId", "date", "status"]
    },
    "User": {
      "title": "User",
      "description": "App user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of services offered"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of all bookings"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
